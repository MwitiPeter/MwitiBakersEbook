PORT=5000
MONGODB_URI=mongodb://localhost:27017/mwiti_bakers
JWT_SECRET=your_super_secret_key_change_this
PAYSTACK_SECRET_KEY=your_paystack_secret_key
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
FRONTEND_URL=http://localhost:5173

# Resend (Email) — REQUIRED for signup, password reset & email verification
# Get a FREE API key at https://resend.com/api-keys (100 emails/day free)
# Without this, password reset and email verification will fail.
# On the free tier, emails are sent from 'onboarding@resend.dev'.
# For a custom sender (e.g. noreply@yourdomain.com), verify your domain in Resend dashboard.
RESEND_API_KEY=
FROM_EMAIL=Mwiti Bakers <onboarding@resend.dev>

# Admin seed credentials (used with npm run seed)
ADMIN_EMAIL=admin@mwitibakers.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Admin
